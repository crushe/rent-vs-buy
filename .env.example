# The canonical URL for the deployed site (used by sitemap.xml and robots.txt).
# If unset, falls back to https://rentvsbuy.netlify.app
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase configuration
# Get these from your Supabase project dashboard: Settings → API
#
# These are safe to expose to the browser (anon key has RLS protection).
# If left blank, the app still works with URL sharing and PDF export -
# only the save-to-account feature will be hidden.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
